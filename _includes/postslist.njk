<ol reversed class="grid{% if category and niepce.grid_tags %} {{ niepce.grid_tags }}{% else %} {{ niepce.grid }}{% endif %}">
{% for post in postslist | reverse %}
	{% set loading = "eager" if loop.index < 20 else "lazy" %}
	<li class="post">
		<a href="{{ post.url }}" {% if post.data.tw %}class="tw"{% endif %}>
			{% if post.data.photo %}
			<img eleventy:ignore src="{{ post | getPhotoInfos('url') }}" alt="{{ post.data.photo_alt }}" width="{{ post | getPhotoInfos('width') }}" height="{{ post | getPhotoInfos('height') }}">
			{% endif %}
			{% if post.data.tw %}
			<div class="post-tw"><abbr title="Trigger warning">TW:</abbr> {{ post.data.tw }}</div>
			{% endif %}
			<h2 class="post-title">{{ post.data.title }}</h2>
		</a>
	</li>
{% endfor %}
</ol>
