---
permalink: /feeds/posts.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:base="{{ niepce.language }}">
	<title>{{ niepce.title }}</title>
	<subtitle>{{ niepce.description }}</subtitle>
	<link href="{{ permalink | htmlBaseUrl(niepce.url) }}" rel="self" />
	<link href="{{ niepce.url | addPathPrefixToFullUrl }}" />
	<updated>{{ collections.posts | getNewestCollectionItemDate | dateToRfc3339 }}</updated>
	<id>{{ niepce.url }}</id>
	<author>
		<name>{{ niepce.author.name }}</name>
		<email>{{ niepce.author.email }}</email>
	</author>
	{%- for post in collections.posts | reverse %}
	{% set absolutePostUrl %}{{ post.url | htmlBaseUrl(niepce.url) }}{% endset %}
	<entry>
		<title>{{ post.data.title }}</title>
		<link href="{{ absolutePostUrl }}" />
		<updated>{{ post.date | dateToRfc3339 }}</updated>
		<id>{{ absolutePostUrl }}</id>
		<content type="html">
			<![CDATA[
			{% if post.data.photo %}
			<img	src="{{ absolutePostUrl }}{{ post.data.photo }}" alt="{{ post.data.photo_alt }}">
			{% endif %}
			{{ post.templateContent | transformWithHtmlBase(absolutePostUrl, post.url) | safe }}
			]]>
		</content>
	</entry>
	{%- endfor %}
</feed>
